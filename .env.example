# Environment Configuration for 4ViegoMains

# Application
NODE_ENV=development
LOG_LEVEL=info

# API Configuration
API_URL=http://localhost:8000
API_PORT=8000

# Riot API
RIOT_API_KEY=your_riot_api_key_here
RIOT_API_REGION=na1

# Database - PostgreSQL
POSTGRES_USER=viego
POSTGRES_PASSWORD=viego_pass
POSTGRES_DB=viego_db
POSTGRES_URL=postgres://viego:viego_pass@postgres:5432/viego_db
POSTGRES_MAX_CONNECTIONS=20

# Database - ClickHouse
CLICKHOUSE_USER=viego
CLICKHOUSE_PASSWORD=clickhouse_pass
CLICKHOUSE_DB=viego
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_NATIVE_PORT=9000

# Cache - Redis
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
REDIS_MAX_RETRIES=3

# Message Queue - NATS
NATS_URL=nats://nats:4222
NATS_CLUSTER_NAME=viego-cluster

# Frontend
REACT_APP_API_URL=http://localhost:8000
REACT_APP_VERSION=1.0.0

# Monitoring
PROMETHEUS_RETENTION_DAYS=15
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_PROVISIONING_PATH=/etc/grafana/provisioning

# Service Ports (for dev)
RIOT_GATEWAY_PORT=8001
CHAMPION_SVC_PORT=8002
PLAYER_SVC_PORT=8003
ANALYTICS_SVC_PORT=8004
LEADERBOARD_SVC_PORT=8005
CONTENT_SVC_PORT=8006
DATA_WORKER_PORT=8007

# Security
SSL_CERT_PATH=/etc/nginx/certs/cert.pem
SSL_KEY_PATH=/etc/nginx/certs/key.pem
JWT_SECRET=your_jwt_secret_key_here
CORS_ORIGIN=http://localhost:3001

# Feature Flags
ENABLE_MATCH_HISTORY=true
ENABLE_ANALYTICS=true
ENABLE_LEADERBOARD=true
ENABLE_CONTENT_GUIDES=true
ENABLE_META_STATS=true

# Data Configuration
DATA_RETENTION_DAYS=180
MATCH_HISTORY_LIMIT=100
LEADERBOARD_LIMIT=100

# External Services
DDRAGON_URL=https://ddragon.leagueoflegends.com
COMMUNITY_DRAGON_URL=https://cdn.communitydragon.org

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_SECOND=30
RATE_LIMIT_SEARCH_REQUESTS_PER_SECOND=5

# Timeouts (in seconds)
HTTP_CLIENT_TIMEOUT=30
DB_CONNECTION_TIMEOUT=10
CACHE_TTL_SECONDS=3600

# Worker Configuration
WORKER_CONCURRENCY=5
WORKER_MAX_RETRIES=3
WORKER_BATCH_SIZE=100
